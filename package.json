{
  "name": "poker-engine-ts",
  "version": "0.1.3",
  "description": "The most complete open-source, event-sourced poker engine for production backends. The rules are data; Texas Hold'em is the variant that ships today.",
  "license": "MIT",
  "author": "Limin (liminge.space)",
  "homepage": "https://liminge.space",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ge-limin/poker-engine-ts.git"
  },
  "type": "module",
  "keywords": [
    "poker",
    "texas-holdem",
    "holdem",
    "nlhe",
    "poker-engine",
    "hand-evaluator",
    "event-sourcing",
    "card-game",
    "game-engine",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./persistence/supabase": {
      "types": "./dist/persistence/supabase/index.d.ts",
      "import": "./dist/persistence/supabase/index.js"
    },
    "./adapters/client": {
      "types": "./dist/session/adapters/client.d.ts",
      "import": "./dist/session/adapters/client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm lint && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "fixtures:lint": "node ./scripts/lint-fixtures.mjs",
    "scenario:run": "tsx ./scripts/run-scenarios.ts",
    "example:quickstart": "tsx ./examples/quickstart.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@supabase/supabase-js": "^2.58.0",
    "@types/node": "^24.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "fast-check": "^3.23.2",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.26.0+sha512.3b3f6c725ebe712506c0ab1ad4133cf86b1f4b687effce62a9b38b4d72e3954242e643190fc51fa1642949c735f403debd44f5cb0edd657abe63a8b6a7e1e402"
}
